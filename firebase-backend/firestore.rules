rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isParentOf(childId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/children/$(childId)) &&
        get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
    }
    
    function getUserMode() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.mode;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        // Prevent modifying subscription directly (must go through functions)
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);
      allow delete: if false; // Never delete users directly
    }

    // Devices - users can manage their devices, parents can manage children's devices
    match /devices/{deviceId} {
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid ||
         isParentOf(resource.data.linkedChildId));
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         isParentOf(resource.data.linkedChildId));
      allow delete: if false; // Devices can only be unlinked, not deleted
    }

    // Owner profiles - only the owner can access
    match /owner_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Family profiles - only parent can access
    match /family_profiles/{familyId} {
      allow read: if isAuthenticated() && 
        resource.data.parentUid == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.parentUid == request.auth.uid;
      allow update: if isAuthenticated() && 
        resource.data.parentUid == request.auth.uid;
      allow delete: if false;
    }

    // Children - parent can manage, read only for linked devices
    match /children/{childId} {
      allow read: if isAuthenticated() && 
        (resource.data.parentUid == request.auth.uid ||
         resource.data.devices.hasAny([request.auth.token.deviceId]));
      allow create, update: if isAuthenticated() && 
        request.resource.data.parentUid == request.auth.uid;
      allow delete: if false;
    }

    // Block policies - read by authenticated users, write by admins only
    match /block_policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Global blocklists - read only for all authenticated
    match /blocklists/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Custom blocklists - user can manage their own
    match /blocklists/custom/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Override requests - owner/parent can create, read their own
    match /override_requests/{requestId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if false; // Only functions can update
      allow delete: if false;
    }

    // Logs - read only for owner, write by system
    match /logs/{logId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Subscriptions - read only, managed by functions
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can modify
    }

    // Fraud scores - not accessible to clients
    match /fraud_scores/{userId} {
      allow read, write: if false; // Only Cloud Functions
    }

    // Region pricing - read by all authenticated
    match /region_pricing/{region} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Device registry - read/write by functions only
    match /device_registry/{fingerprint} {
      allow read, write: if false; // Only Cloud Functions
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false; // Manual only
    }
  }
}
