rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isParentOf(childId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/children/$(childId)) &&
        get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
    }
    
    function getUserMode() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.mode;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isOwnerMode() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.mode == 'owner';
    }
    
    function isFamilyMode() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.mode == 'family';
    }
    
    // Rate limiting helper - checks writes in last minute
    function rateLimitCheck(path, maxWrites) {
      // Note: Firestore doesn't have native rate limiting in rules
      // This is a placeholder - implement via Cloud Functions
      return true;
    }

    // ============================================
    // VERSION & CONFIG (Read-only for clients)
    // ============================================
    
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Only admins can update version
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      // Allow creating new user document with any fields
      allow create: if isOwner(userId);
      // Users can update their profile, but NOT subscription or security fields
      // Subscription fields are managed exclusively by Cloud Functions
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['subscription', 'master_key_hash', 'createdAt']);
      // Allow users to delete their own account
      allow delete: if isOwner(userId);
    }

    // ============================================
    // DEVICES
    // ============================================
    
    match /devices/{deviceId} {
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid ||
         isParentOf(resource.data.linkedChildId));
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         isParentOf(resource.data.linkedChildId)) &&
        // Prevent changing ownership
        request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Devices can only be unlinked, not deleted
    }

    // ============================================
    // OWNER PROFILES (Ultra-strict mode settings)
    // ============================================
    
    match /owner_profiles/{userId} {
      allow read: if isOwner(userId);
      // Allow creating owner profiles — must include master_key_hash
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['master_key_hash', 'createdAt']) &&
        request.resource.data.master_key_hash is string &&
        request.resource.data.master_key_hash.size() >= 60;
      // Users can update settings but NOT master_key_hash, createdAt, or userId
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['master_key_hash', 'createdAt', 'userId']);
      // Users can delete their own profile
      allow delete: if isOwner(userId);
    }

    // ============================================
    // FAMILY PROFILES
    // ============================================
    
    match /family_profiles/{familyId} {
      allow read: if isAuthenticated() && 
        resource.data.parentUid == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.parentUid == request.auth.uid &&
        // Must be in family mode to create family profiles
        isFamilyMode();
      allow update: if isAuthenticated() && 
        resource.data.parentUid == request.auth.uid;
      allow delete: if false;
    }

    // ============================================
    // CHILDREN
    // ============================================
    
    match /children/{childId} {
      // Support both parentId and parentUid fields
      allow read: if isAuthenticated() && 
        (resource.data.parentUid == request.auth.uid || resource.data.parentId == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.parentUid == request.auth.uid || request.resource.data.parentId == request.auth.uid);
      allow update: if isAuthenticated() && 
        (resource.data.parentUid == request.auth.uid || resource.data.parentId == request.auth.uid);
      allow delete: if isAuthenticated() && 
        (resource.data.parentUid == request.auth.uid || resource.data.parentId == request.auth.uid);
    }

    // ============================================
    // BLOCK POLICIES (Read by users, write by admins)
    // ============================================
    
    match /block_policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // BLOCKLISTS
    // ============================================
    
    // Global blocklist - NEVER writable by clients
    match /blocklists/global {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }
    
    // Core blocklist - NEVER writable by clients (permanent adult block)
    match /blocklists/core {
      allow read: if isAuthenticated();
      allow write: if false; // Never - this is the permanent blocklist
    }

    // Custom user blocklists
    match /blocklists/custom/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Category blocklists
    match /blocklists/categories/{category} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // STUDY SESSIONS
    // ============================================
    
    // The app uses study_sessions collection
    match /study_sessions/{sessionId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Legacy path (if any)
    match /studySessions/{sessionId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // User study sessions subcollection
    match /users/{userId}/studySessions/{sessionId} {
      allow read, write: if isOwner(userId);
    }

    // ============================================
    // BLOCKED CREATORS
    // ============================================
    
    // The app uses blocked_creators collection
    match /blocked_creators/{creatorId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Legacy paths
    match /creators/{userId}/blocked/{creatorId} {
      allow read, write: if isOwner(userId);
    }
    
    // User blocked creators subcollection
    match /users/{userId}/blockedCreators/{creatorId} {
      allow read, write: if isOwner(userId);
    }

    // ============================================
    // OVERRIDE REQUESTS
    // ============================================
    
    match /override_requests/{requestId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if false; // Only Cloud Functions can update
      allow delete: if false;
    }

    // ============================================
    // LOGS (Activity logs - read only)
    // ============================================
    
    match /logs/{logId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        // Rate limit: max 10 writes per request (batch protection)
        request.resource.data.keys().size() < 20;
      allow update, delete: if false;
    }

    // ============================================
    // ERROR LOGS
    // ============================================
    
    match /errorLogs/{userId}/entries/{entryId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    // ============================================
    // ADMIN LOGS (Override attempts, unlocks, etc.)
    // ============================================
    
    match /admin_logs/{userId}/events/{eventId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    // ============================================
    // SUBSCRIPTIONS (Read-only, managed by functions)
    // ============================================
    
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can modify
    }

    // ============================================
    // FRAUD SCORES (Not accessible to clients)
    // ============================================
    
    match /fraud_scores/{userId} {
      allow read, write: if false; // Only Cloud Functions
    }

    // ============================================
    // REGION PRICING
    // ============================================
    
    match /region_pricing/{region} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // DEVICE REGISTRY (Functions only)
    // ============================================
    
    match /device_registry/{fingerprint} {
      allow read, write: if false; // Only Cloud Functions
    }

    // ============================================
    // RATE LIMITS (Functions only)
    // ============================================
    
    match /rate_limits/{userId} {
      allow read, write: if false; // Only Cloud Functions manage this
    }

    // ============================================
    // ADMINS COLLECTION
    // ============================================
    
    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false; // Manual only
    }

    // ============================================
    // SECURITY EVENTS (Parent alert system)
    // ============================================
    
    match /security_events/{userId}/{deviceId}/{eventId} {
      // Users can only read their own security events
      allow read: if isOwner(userId);
      // Only authenticated users can write via extension
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if false; // Events are immutable
    }

    // ============================================
    // ALERTS (Parent notifications) - Flat collection with userId field
    // ============================================
    
    match /alerts/{alertId} {
      // Users can read and list their own alerts only
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false; // Only Cloud Functions
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        // Only allow marking as read (cannot un-read)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']) &&
        request.resource.data.read == true;
      // Users can delete their own alerts
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // ALERT SETTINGS
    // ============================================
    
    match /alert_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ============================================
    // MAIL (Firebase Email Extension)
    // ============================================
    
    match /mail/{mailId} {
      // Only Cloud Functions can write emails
      allow read, write: if false;
    }

    // ============================================
    // OPERATIONAL COLLECTIONS (Cloud Functions only)
    // Server-only: Admin SDK bypasses these rules
    // ============================================
    
    match /critical_errors/{errorId} {
      allow read, write: if false;
    }
    
    match /critical_errors_archive/{errorId} {
      allow read, write: if false;
    }
    
    match /security_events/{eventId} {
      allow read, write: if false;
    }
    
    match /metrics/{metricId} {
      allow read, write: if false;
    }
    
    match /deletion_queue/{jobId} {
      allow read, write: if false;
    }
    
    match /manual_cleanup_queue/{jobId} {
      allow read, write: if false;
    }
    
    match /failed_deletions/{failId} {
      allow read, write: if false;
    }
    
    // M-01: Previously missing server-only collections
    // Admin SDK bypasses these rules, so Cloud Functions still work
    
    match /digest_queue/{queueId} {
      allow read, write: if false;
    }
    
    match /email_caps/{capId} {
      allow read, write: if false;
    }
    
    match /alert_cooldown/{cooldownId} {
      allow read, write: if false;
    }
    
    // User blocks subcollection (written by AI classification)
    match /users/{userId}/blocks/{blockId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions
    }
  }
}
