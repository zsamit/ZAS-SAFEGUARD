{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": "npm --prefix \"$RESOURCE_DIR\" run lint"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/",              "destination": "/landing.html" },
      { "source": "/features",      "destination": "/features.html" },
      { "source": "/pricing",       "destination": "/pricing.html" },
      { "source": "/changelog",     "destination": "/changelog.html" },
      { "source": "/status",        "destination": "/status.html" },
      { "source": "/about",         "destination": "/about.html" },
      { "source": "/blog",          "destination": "/blog.html" },
      { "source": "/careers",       "destination": "/careers.html" },
      { "source": "/cookie-policy", "destination": "/cookie-policy.html" },
      { "source": "/help",          "destination": "/help.html" },
      { "source": "/contact",       "destination": "/contact.html" },
      { "source": "/security",      "destination": "/security.html" },
      { "source": "/app/**",        "destination": "/index.html" },
      { "source": "/register",      "destination": "/index.html" },
      { "source": "/login",         "destination": "/index.html" },
      { "source": "/checkout/**",   "destination": "/index.html" },
      { "source": "**",             "destination": "/index.html" }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true
    }
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.4"
  }
}
